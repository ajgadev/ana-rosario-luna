---
import { DESIGNS } from "../../data/designs";
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ana Rosario Luna · Elige tu diseño favorito</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --bg: #f6f2ea; --bg-2: #ebe3d2; --ink: #211e1a; --ink-2: #5c5246;
        --mute: #9a8e80; --line: #d6cab1; --accent: #b05a3c;
        --serif: "Cormorant Garamond", Georgia, serif;
        --sans: "Plus Jakarta Sans", system-ui, sans-serif;
        --mono: "JetBrains Mono", monospace;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body { font-family: var(--sans); background: var(--bg); color: var(--ink); line-height: 1.55; -webkit-font-smoothing: antialiased; }
      a { color: inherit; text-decoration: none; }
      h1, h2, h3 { margin: 0; font-weight: 400; letter-spacing: -0.015em; }
      h1 { font-family: var(--serif); font-size: clamp(48px, 6vw, 84px); line-height: 1.05; }
      h2 { font-family: var(--serif); font-size: clamp(28px, 2.4vw, 40px); line-height: 1.1; }
      h3 { font-family: var(--serif); font-size: 24px; line-height: 1.2; }
      p { margin: 0; color: var(--ink-2); }
      .wrap { max-width: 1320px; margin: 0 auto; padding: 0 40px; }
      @media (max-width: 720px) { .wrap { padding: 0 24px; } }
      header { padding: 32px 0; border-bottom: 1px solid var(--line); }
      .head-row { display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
      .brand { display: flex; align-items: center; gap: 12px; font-family: var(--serif); font-size: 20px; }
      .brand .mark { width: 34px; height: 34px; border-radius: 50%; background: var(--accent); color: #fff; display: grid; place-items: center; font-style: italic; font-size: 15px; }
      .brand em { font-style: italic; color: var(--ink-2); }
      .head-meta { font-family: var(--mono); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--mute); }
      .head-meta .dot { display: inline-block; width: 6px; height: 6px; background: var(--accent); border-radius: 50%; margin-right: 8px; vertical-align: middle; }
      .intro { padding: 88px 0 64px; }
      .intro-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 48px; align-items: end; }
      @media (max-width: 920px) { .intro-grid { grid-template-columns: 1fr; gap: 32px; } }
      .eyebrow { font-family: var(--mono); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--mute); display: inline-flex; align-items: center; gap: 10px; }
      .eyebrow::before { content: ""; width: 24px; height: 1px; background: var(--accent); }
      .intro h1 { margin-top: 24px; text-wrap: balance; }
      .intro h1 em { font-style: italic; color: var(--ink-2); font-weight: 400; }
      .intro h1 .acc { color: var(--accent); }
      .intro-sub { font-size: 18px; line-height: 1.6; max-width: 48ch; color: var(--ink-2); font-family: var(--serif); font-style: italic; font-size: 22px; }
      .intro-meta { display: grid; grid-template-columns: repeat(3, auto); gap: 32px; margin-top: 24px; padding-top: 24px; border-top: 1px solid var(--line); font-family: var(--mono); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--mute); }
      .intro-meta strong { display: block; font-family: var(--sans); font-size: 14px; color: var(--ink); letter-spacing: 0.02em; text-transform: none; margin-top: 4px; font-weight: 500; }
      .designs { padding: 48px 0 120px; }
      .grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 32px; }
      @media (max-width: 920px) { .grid { grid-template-columns: 1fr; } }
      .card { background: var(--bg-2); border-radius: 16px; overflow: hidden; display: flex; flex-direction: column; transition: transform 0.35s ease, box-shadow 0.35s ease; border: 1px solid var(--line); }
      .card:hover { transform: translateY(-4px); box-shadow: 0 24px 48px -20px rgba(40, 30, 15, 0.15); }
      .card .preview { aspect-ratio: 16/10; position: relative; overflow: hidden; border-bottom: 1px solid var(--line); background: #fff; }
      .card .preview iframe { position: absolute; top: 0; left: 0; width: 250%; height: 250%; transform: scale(0.4); transform-origin: 0 0; border: 0; pointer-events: none; }
      .card .preview .overlay { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 60%, rgba(0, 0, 0, 0.04)); pointer-events: none; }
      .card .body { padding: 28px 28px 24px; display: flex; flex-direction: column; gap: 16px; }
      .card .num { font-family: var(--mono); font-size: 11px; letter-spacing: 0.18em; color: var(--accent); text-transform: uppercase; }
      .card .num .pill { margin-left: 12px; padding: 3px 10px; border: 1px solid var(--line); border-radius: 999px; color: var(--mute); font-size: 10px; }
      .card h2 { font-weight: 400; letter-spacing: -0.015em; }
      .card .desc { font-size: 15px; line-height: 1.6; color: var(--ink-2); max-width: 50ch; }
      .card .props { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 4px; }
      .card .prop { font-family: var(--mono); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-2); padding: 5px 10px; background: var(--bg); border: 1px solid var(--line); border-radius: 999px; }
      .card .swatches { display: flex; gap: 6px; margin-top: 6px; }
      .card .swatches span { width: 28px; height: 28px; border-radius: 50%; border: 1px solid rgba(0, 0, 0, 0.05); }
      .card .foot { display: flex; justify-content: space-between; align-items: center; margin-top: auto; padding-top: 20px; border-top: 1px solid var(--line); }
      .card .foot .meta { font-family: var(--mono); font-size: 10px; letter-spacing: 0.16em; color: var(--mute); text-transform: uppercase; }
      .card .foot .cta { display: inline-flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 500; padding: 10px 16px; background: var(--ink); color: var(--bg); border-radius: 8px; transition: background 0.25s; }
      .card:hover .foot .cta { background: var(--accent); }
      .foot-bar { padding: 48px 0; border-top: 1px solid var(--line); font-family: var(--mono); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--mute); }
      .foot-row { display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
      .note { margin-top: 48px; padding: 32px; background: var(--bg-2); border-radius: 12px; border: 1px solid var(--line); display: flex; gap: 24px; align-items: flex-start; flex-wrap: wrap; }
      .note .l { flex: 1; min-width: 260px; }
      .note h3 { margin-bottom: 8px; }
      .note p { font-size: 15px; line-height: 1.6; }
      .note .icon { width: 48px; height: 48px; border-radius: 50%; background: var(--accent); color: #fff; display: grid; place-items: center; font-family: var(--serif); font-style: italic; font-size: 22px; flex-shrink: 0; }
    </style>
  </head>
  <body>
    <header>
      <div class="wrap head-row">
        <div class="brand"><span class="mark">a</span> Ana Rosario <em>Luna</em></div>
        <div class="head-meta"><span class="dot"></span> 8 direcciones de diseño · landing page</div>
      </div>
    </header>

    <section class="intro">
      <div class="wrap intro-grid">
        <div>
          <span class="eyebrow">Elige tu diseño favorito</span>
          <h1>Ocho maneras <em>distintas</em> de presentar la <span class="acc">misma</span> consulta.</h1>
        </div>
        <div>
          <p class="intro-sub">
            Recorre las ocho direcciones, ábrelas a pantalla completa y juega
            con las paletas y tipografías desde el panel «Tweaks». Apunta tus
            notas y dime cuál te representa mejor.
          </p>
          <div class="intro-meta">
            <div>Audiencia<strong>Adultos 25-55 · España</strong></div>
            <div>Idioma<strong>Español (ES)</strong></div>
            <div>Formato<strong>Single-page · Responsive</strong></div>
          </div>
        </div>
      </div>
    </section>

    <section class="designs">
      <div class="wrap">
        <div class="grid">
          {
            DESIGNS.filter((d) => d.id !== "08").map((d) => (
              <a class="card" href={`/showcase/${d.id}`}>
                <div class="preview">
                  <iframe src={`/designs/${d.id}/index.html`} loading="lazy" scrolling="no" tabindex="-1" title={`Vista previa ${d.name}`} />
                  <div class="overlay" />
                </div>
                <div class="body">
                  <div class="num">
                    {d.id} — {d.name} <span class="pill">{d.pill}</span>
                  </div>
                  <h2>{d.title}.</h2>
                  <p class="desc">{d.desc}</p>
                  <div class="swatches">
                    {d.swatches.map((c) => (
                      <span style={`background:${c}`} />
                    ))}
                  </div>
                  <div class="props">
                    {d.props.map((p) => (
                      <span class="prop">{p}</span>
                    ))}
                  </div>
                  <div class="foot">
                    <span class="meta">{d.sections}</span>
                    <span class="cta">Abrir diseño →</span>
                  </div>
                </div>
              </a>
            ))
          }
        </div>

        <div class="note">
          <div class="icon">i</div>
          <div class="l">
            <h3>Cómo usar esta página</h3>
            <p>
              Cada tarjeta abre la versión interactiva real (no una imagen).
              Recorre las ocho, usa el panel «Tweaks» de la esquina para probar
              paletas, tipografías y formas, escribe tus notas y pulsa «Copiar
              selección» para enviármelas. Puedo mezclar elementos (por ejemplo:
              el hero de la 08 con la paleta de la 06) o evolucionar una sola
              hasta producción.
            </p>
          </div>
        </div>
      </div>
    </section>

    <footer class="foot-bar">
      <div class="wrap foot-row">
        <span>Ana Rosario Luna · 8 direcciones de diseño · 2026</span>
        <span>Para producción: una sola dirección · todas son responsive</span>
      </div>
    </footer>
  </body>
</html>
